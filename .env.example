# ═══════════════════════════════════════════════
# PlantaOS MVP — Environment Variables
# Copy to .env and fill in values
# ═══════════════════════════════════════════════

# ── App Configuration ─────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8050
DEBUG=true
LOG_LEVEL=DEBUG

# ── Data Configuration ────────────────────────
DATA_REFRESH_INTERVAL=30
SYNTHETIC_DAYS=30

# ── AI Insights (Claude API) ─────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# ── Optional: Database ────────────────────────
# DATABASE_URL=sqlite:///plantaos.db
